<UserControl x:Class="TapoCtrl.Controls.DevicePanel" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" MinWidth="80" MinHeight="28">
 <Border x:Name="RootBorder" ClipToBounds="True" Background="#242932" BorderBrush="#55606F" BorderThickness="2" CornerRadius="10" Padding="4">
  <Grid>
   <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
   <Grid>
    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
    <Border x:Name="SelectionBadge" Width="15" Height="15" Margin="0,0,7,0" CornerRadius="3" BorderThickness="1" BorderBrush="#8793A3" Background="#303741" Visibility="Collapsed">
     <TextBlock Text="✓" FontSize="11" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Border>
    <TextBlock x:Name="NameText" Grid.Column="1" Foreground="#B8C1CC" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" ToolTip="ホイール: 名前サイズ / Shift+ホイール: 名前色"/>
    <Border x:Name="PowerStateBorder" Grid.Column="2" CornerRadius="8" Padding="7,2" Margin="8,0,0,0" Visibility="Collapsed">
     <TextBlock x:Name="PowerStateText" FontSize="11" FontWeight="Bold" Foreground="White"/>
    </Border>
   </Grid>
   <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
     <TextBlock x:Name="ValueNumberText" Foreground="#F2F5F7" FontSize="32" FontWeight="Bold" TextAlignment="Center" ToolTip="ホイール: 測定値サイズ"/>
     <TextBlock x:Name="ValueUnitText" Foreground="#F2F5F7" FontSize="16" FontWeight="SemiBold" Margin="5,0,0,2" VerticalAlignment="Bottom"/>
    </StackPanel>
    <StackPanel x:Name="SecondaryValuePanel" Orientation="Horizontal" HorizontalAlignment="Center" Visibility="Collapsed">
     <TextBlock x:Name="SecondaryNumberText" Foreground="#F2F5F7" FontSize="26" FontWeight="SemiBold" ToolTip="ホイール: 測定値サイズ"/>
     <TextBlock x:Name="SecondaryUnitText" Foreground="#F2F5F7" FontSize="13" FontWeight="SemiBold" Margin="4,0,0,1" VerticalAlignment="Bottom"/>
    </StackPanel>
    <TextBlock x:Name="SummaryText" Visibility="Collapsed" Foreground="#B58CFF" FontSize="17" FontWeight="SemiBold" TextAlignment="Center" Margin="0,4,0,0"/>
   </StackPanel>
   <TextBlock x:Name="SubText" Grid.Row="2" Foreground="#9EA8B5" FontSize="10"/>
   <Thumb x:Name="ResizeThumb" Grid.RowSpan="3" Width="17" Height="17" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" Background="#8995A5" BorderBrush="#D7DEE8" BorderThickness="1" Opacity="0.75" ToolTip="ドラッグしてサイズ変更"/>
  </Grid>
 </Border>
</UserControl>
