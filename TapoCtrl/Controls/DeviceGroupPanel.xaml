<UserControl x:Class="TapoCtrl.Controls.DeviceGroupPanel" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" MinWidth="260" MinHeight="32">
 <Border x:Name="GroupBorder" Background="#1F242C" BorderThickness="2" CornerRadius="12" Padding="8">
  <Grid>
   <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
   <Border x:Name="HeaderBorder" CornerRadius="7" Padding="8,2" Cursor="SizeAll">
    <DockPanel><StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><TextBlock x:Name="CountText" Foreground="#30343A" VerticalAlignment="Center" Margin="0,0,8,0"/><Button x:Name="GraphButton" Content="グラフ" Padding="8,1" Margin="0,0,5,0" ToolTip="系列グラフを開く"/><Button x:Name="CollapseButton" Content="▼" Width="28" Padding="2,1" ToolTip="展開・折りたたみ"/></StackPanel><TextBlock x:Name="TitleText" FontWeight="Bold" FontSize="13" Foreground="#171A1F" VerticalAlignment="Center"/></DockPanel>
   </Border>
   <ScrollViewer x:Name="ItemsScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="0,4,0,0">
    <Canvas x:Name="ItemsHost" Background="Transparent"/>
   </ScrollViewer>
   <Thumb x:Name="ResizeThumb" Grid.RowSpan="2" Width="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" Background="#8B95A3" Opacity="0.7"/>
  </Grid>
 </Border>
</UserControl>
