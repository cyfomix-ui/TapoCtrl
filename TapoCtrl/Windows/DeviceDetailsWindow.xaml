<Window x:Class="TapoCtrl.Windows.DeviceDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TapoCtrl デバイス詳細" Width="440" Height="520"
        Background="#171B21" Foreground="#F4F7FA"
        WindowStartupLocation="Manual" ShowInTaskbar="False" Topmost="False">
    <Border Background="#171B21" BorderBrush="#25A7E8" BorderThickness="1.4" Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel Margin="0,0,0,12" LastChildFill="False">
                <TextBlock x:Name="HeaderText" DockPanel.Dock="Left" Text="デバイス詳細" Foreground="#F4F7FA" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right" Content="×" Width="42" Height="32" Click="Close_Click"
                        Background="#B64048" Foreground="White" BorderBrush="#D76169" FontSize="18"/>
            </DockPanel>
            <ListView x:Name="DetailsList" Grid.Row="1" Background="#20262E" BorderBrush="#3C4653" Foreground="#F4F7FA"
                      PreviewMouseRightButtonDown="DetailsList_PreviewMouseRightButtonDown">
                <ListView.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#155A78"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#155A78"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#FFFFFF"/>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="#20262E"/>
                        <Setter Property="Foreground" Value="#F4F7FA"/>
                        <Setter Property="Padding" Value="8,5"/>
                        <Setter Property="BorderBrush" Value="#333D49"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#155A78"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="BorderBrush" Value="#43C7FF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsKeyboardFocusWithin" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Background" Value="#155A78"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </MultiTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.Resources>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="項目" Width="120" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="値" Width="260" DisplayMemberBinding="{Binding Value}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Border>
</Window>
