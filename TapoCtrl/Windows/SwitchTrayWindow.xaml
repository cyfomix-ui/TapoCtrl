<Window x:Class="TapoCtrl.Windows.SwitchTrayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TapoCtrl スイッチ" Width="340" Height="560"
        WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False"
        Topmost="True" AllowsTransparency="True" Background="Transparent">
    <Border Background="#171B21" BorderBrush="#25A7E8" BorderThickness="1.5" CornerRadius="10" Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel Margin="2,0,2,8" LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Text="TapoCtrl スイッチ" Foreground="#F4F7FA" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right" Content="×" Width="34" Height="28" Click="Close_Click"
                        Background="#B64048" Foreground="White" BorderBrush="#D76169" FontSize="17"/>
            </DockPanel>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="ItemsHost"/>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
