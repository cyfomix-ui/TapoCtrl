<Window x:Class="TapoCtrl.Windows.ElectricitySettingsWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="電気料金設定" Width="430" Height="340" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#20242B" Foreground="#F2F5F7">
 <Grid Margin="22"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
  <TextBlock Text="地域" VerticalAlignment="Center" Margin="0,0,8,12"/><ComboBox x:Name="RegionBox" Grid.Column="1" Margin="0,0,0,12" IsEditable="True"><ComboBoxItem Content="関東"/><ComboBoxItem Content="北海道"/><ComboBoxItem Content="東北"/><ComboBoxItem Content="中部"/><ComboBoxItem Content="関西"/><ComboBoxItem Content="中国"/><ComboBoxItem Content="四国"/><ComboBoxItem Content="九州"/></ComboBox>
  <TextBlock Grid.Row="1" Text="電力会社" VerticalAlignment="Center" Margin="0,0,8,12"/><ComboBox x:Name="CompanyBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,12" IsEditable="True"><ComboBoxItem Content="東京電力"/><ComboBoxItem Content="関西電力"/><ComboBoxItem Content="中部電力"/></ComboBox>
  <TextBlock Grid.Row="2" Text="契約容量" VerticalAlignment="Center" Margin="0,0,8,12"/><ComboBox x:Name="CapacityBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,12" IsEditable="True"><ComboBoxItem Content="20A"/><ComboBoxItem Content="30A"/><ComboBoxItem Content="40A"/><ComboBoxItem Content="50A"/><ComboBoxItem Content="60A"/></ComboBox>
  <TextBlock Grid.Row="3" Text="目安単価" VerticalAlignment="Center"/><Grid Grid.Row="3" Grid.Column="1"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="RateBox" VerticalContentAlignment="Center"/><TextBlock Grid.Column="1" Text="円/kWh" VerticalAlignment="Center" Margin="8,0,0,0"/></Grid>
  <TextBlock Grid.Row="4" Grid.ColumnSpan="2" Margin="0,18,0,0" Foreground="#AEB8C5" TextWrapping="Wrap" Text="概算料金は、各電力デバイスの本日累計使用量を合算し、この目安単価を掛けて算出します。基本料金や燃料費調整額などは含みません。"/>
  <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="キャンセル" Width="110" Margin="0,0,10,0" Click="Cancel_Click"/><Button Content="保存" Width="110" Click="Save_Click"/></StackPanel>
 </Grid>
</Window>
