<Window x:Class="TapoCtrl.Windows.SeriesGraphWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:TapoCtrl.Controls" Title="系列グラフ" Width="1120" Height="820" Background="#202328" Foreground="#F2F2F2" WindowStartupLocation="CenterOwner" Topmost="False">
 <Grid Margin="12">
  <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
  <Grid Margin="4,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock x:Name="HeaderText" FontSize="18" FontWeight="SemiBold" Foreground="#D6DAE0" VerticalAlignment="Center"/><Button x:Name="CalendarButton" Grid.Column="1" Content="📅" Width="36" Height="30" ToolTip="履歴日付を選択"/></Grid>
  <Popup x:Name="CalendarPopup" Grid.Row="0" PlacementTarget="{Binding ElementName=CalendarButton}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True"><Border Background="#252B35" BorderBrush="#8B95A3" BorderThickness="1" CornerRadius="8" Padding="8"><Calendar x:Name="HistoryCalendar" SelectionMode="SingleDate"/></Border></Popup>
  <Grid x:Name="GraphGrid" Grid.Row="1"/>
  <UniformGrid x:Name="PowerEnergyCards" Grid.Row="2" Columns="4" Margin="0,8,0,4" Visibility="Collapsed">
   <Border Background="#282E37" CornerRadius="8" Margin="3" Padding="8"><StackPanel><TextBlock Text="本日合計" HorizontalAlignment="Center"/><TextBlock x:Name="TodayTotalText" HorizontalAlignment="Center" FontSize="20" FontWeight="SemiBold" Foreground="#72FF9A"/></StackPanel></Border>
   <Border Background="#282E37" CornerRadius="8" Margin="3" Padding="8"><StackPanel><TextBlock Text="本日概算" HorizontalAlignment="Center"/><TextBlock x:Name="TodayCostText" HorizontalAlignment="Center" FontSize="20" FontWeight="SemiBold" Foreground="#72FF9A"/></StackPanel></Border>
   <Border Background="#282E37" CornerRadius="8" Margin="3" Padding="8"><StackPanel><TextBlock Text="月間計" HorizontalAlignment="Center"/><TextBlock x:Name="MonthTotalText" HorizontalAlignment="Center" FontSize="20" FontWeight="SemiBold" Foreground="#72FF9A"/></StackPanel></Border>
   <Border Background="#282E37" CornerRadius="8" Margin="3" Padding="8"><StackPanel><TextBlock Text="月間概算" HorizontalAlignment="Center"/><TextBlock x:Name="MonthCostText" HorizontalAlignment="Center" FontSize="20" FontWeight="SemiBold" Foreground="#72FF9A"/></StackPanel></Border>
  </UniformGrid>
  <TextBlock x:Name="PastEnergyNote" Grid.Row="3" Text="この日の電力量データは保存されていません" Foreground="#C8CED8" Margin="4,6,0,0" Visibility="Collapsed"/>
 </Grid>
</Window>
